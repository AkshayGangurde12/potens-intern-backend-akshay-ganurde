# ──────────────────────────────────────────────────────────────────────────────
# Prisma
# ──────────────────────────────────────────────────────────────────────────────

# Prisma generates the client into node_modules, but if using custom output:
# prisma/generated/

# Prisma Studio temporary files
.prisma/

# ──────────────────────────────────────────────────────────────────────────────
# Docker
# ──────────────────────────────────────────────────────────────────────────────

# Don't ignore docker-compose.yml or Dockerfile (we want those in version control)
# But ignore override files that might contain local config:
docker-compose.override.yml

# ──────────────────────────────────────────────────────────────────────────────
# Temporary files
# ──────────────────────────────────────────────────────────────────────────────

*.tmp
*.temp
.cache/
.tmp/

# ──────────────────────────────────────────────────────────────────────────────
# Optional: Database dumps / backups (if you generate them locally)
# ──────────────────────────────────────────────────────────────────────────────

*.sql
*.dump
backups/

# ──────────────────────────────────────────────────────────────────────────────
# Optional: Lock files (uncomment if using a specific package manager)
# ──────────────────────────────────────────────────────────────────────────────

# If using npm, keep package-lock.json:
# package-lock.json

# If using Yarn 2+ and using Zero-Installs, keep .yarn/ and .pnp.* files
# Otherwise:
# .yarn/
# .pnp.*
# yarn.lock

# If using pnpm:
# pnpm-lock.yaml
